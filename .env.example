# Copier ce fichier en .env et remplir les valeurs.
# Ne JAMAIS commiter .env (déjà dans .gitignore).

# Clé secrète Flask : utilisée pour signer les cookies de session.
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez_moi_avec_une_vraie_cle_aleatoire

# Environnement : development | production
FLASK_ENV=development

# URL de la base de données.
# En dev (SQLite) : sqlite:///campusgive.db
# En prod (PostgreSQL) : postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///campusgive.db
